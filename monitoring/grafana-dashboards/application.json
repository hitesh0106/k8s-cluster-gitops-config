{
  "annotations": {
    "list": []
  },
  "description": "Application-specific metrics dashboard for k8s-cicd-api",
  "editable": false,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=~\"k8s-cicd-.*\"}[5m])) by (status_code)",
          "legendFormat": "{{ status_code }}"
        }
      ]
    },
    {
      "title": "Response Latency (p95)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=~\"k8s-cicd-.*\"}[5m])) by (le, method))",
          "legendFormat": "p95 {{ method }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Error Rate (%)",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=~\"k8s-cicd-.*\", status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=~\"k8s-cicd-.*\"}[5m])) * 100",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "Pod CPU Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"k8s-cicd-.*\", container=\"api\"}[5m])) by (pod)",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
      "title": "Pod Memory Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"k8s-cicd-.*\", container=\"api\"}) by (pod) / 1024 / 1024",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      }
    },
    {
      "title": "Active Replicas vs HPA Desired",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=~\"k8s-cicd-.*\", deployment=~\".*k8s-cicd-api.*\"}",
          "legendFormat": "Available"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=~\"k8s-cicd-.*\"}",
          "legendFormat": "HPA Desired"
        }
      ]
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{namespace=~\"k8s-cicd-.*\"}[5m])) by (pod) / 1024",
          "legendFormat": "RX {{ pod }}"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{namespace=~\"k8s-cicd-.*\"}[5m])) by (pod) / 1024",
          "legendFormat": "TX {{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "KBs"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["application", "k8s-cicd-api"],
  "time": { "from": "now-3h", "to": "now" },
  "title": "K8s CI/CD API - Application Metrics",
  "uid": "k8s-cicd-app-metrics",
  "version": 1
}
