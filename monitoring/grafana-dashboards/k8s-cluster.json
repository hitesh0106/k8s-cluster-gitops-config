{
  "annotations": {
    "list": []
  },
  "description": "Kubernetes Cluster Overview Dashboard",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Cluster CPU Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) / sum(kube_node_status_allocatable{resource=\"cpu\"}) * 100",
          "legendFormat": "CPU Usage %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "Cluster Memory Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container!=\"\"}) / sum(kube_node_status_allocatable{resource=\"memory\"}) * 100",
          "legendFormat": "Memory Usage %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "Total Pods",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{phase=\"Running\"})",
          "legendFormat": "Running"
        }
      ]
    },
    {
      "title": "Node Count",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "count(kube_node_info)",
          "legendFormat": "Nodes"
        }
      ]
    },
    {
      "title": "Failed Pods",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{phase=\"Failed\"})",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "CPU Usage by Namespace",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) by (namespace)",
          "legendFormat": "{{ namespace }}"
        }
      ]
    },
    {
      "title": "Memory Usage by Namespace",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container!=\"\"}) by (namespace) / 1024 / 1024",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      }
    },
    {
      "title": "Pod Restarts (Last 1h)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total[1h]) > 0",
          "legendFormat": "{{ namespace }}/{{ pod }}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["kubernetes", "cluster", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Kubernetes Cluster Overview",
  "uid": "k8s-cluster-overview",
  "version": 1
}
